  <ItemGroup>
    <ProjectReference Include="..\OMS.Domain\OMS.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Connectors\OrderClinic\" />
    <Folder Include="Models\" />
    <Folder Include="Modules\OrderModule\Events\" />
  </ItemGroup>

</Project>
